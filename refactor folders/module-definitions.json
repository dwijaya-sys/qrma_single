        { "paramId": "M10.7",  "key": "bodyFatPct",       "domId": "bc-bf",     "source": "manual",      "type": "number",  "unit": "%" },
        { "paramId": "M10.8",  "key": "visceralFatIndex", "domId": "bc-vf",     "source": "manual",      "type": "number",  "unit": "1-59 Tanita scale" },
        { "paramId": "M10.9",  "key": "whr",              "domId": "bc-whr",    "source": "auto_or_manual", "type": "number", "unit": "ratio",    "note": "Auto-calc from bc-wc/bc-height; manual override via data-manual attr" }
      ],
      "derivedOutputs": [
        { "paramId": "M10.10", "key": "centralAdiposity",    "type": "number", "unit": "0-100", "note": "cai = avg burden(wc, whr) × (100/9)" },
        { "paramId": "M10.11", "key": "bodyCompositionIndex","type": "number", "unit": "0-100", "note": "bci = (burden(bf)×0.6 + burden(vf)×0.4) × (100/9)" },
        { "paramId": "M10.12", "key": "structuralIndex",     "type": "number", "unit": "0-100", "note": "sti = burden(bmi) × (100/9)" },
        { "paramId": "M10.13", "key": "overallRiskScore",    "type": "number", "unit": "0-100", "note": "cai×0.40 + bci×0.35 + sti×0.25; partial scoring when fields absent" },
        { "paramId": "M10.14", "key": "bmrKcal",             "type": "number", "unit": "kcal/day", "note": "Mifflin-St Jeor; informational only — no zone classification" }
      ],
      "zoneThresholds": {
        "bmi": {
          "source": "Standard WHO (bidirectional)",
          "berat_low":   "< 16.0",
          "sedang_low":  "16.0–16.9",
          "ringan_low":  "17.0–18.4",
          "normal":      "18.5–24.9",
          "ringan_high": "25.0–27.4",
          "sedang_high": "27.5–29.9",
          "berat_high":  "≥ 30.0"
        },
        "waistCircumference": {
          "source": "IDF South/Southeast Asian",
          "male":   { "normal": "< 90", "ringan": "90–94", "sedang": "95–99", "berat": "≥ 100" },
          "female": { "normal": "< 80", "ringan": "80–84", "sedang": "85–89", "berat": "≥ 90"  }
        },
        "bodyFatPct": {
          "source": "ACSM by sex and age bracket",
          "male_under40":   { "normal": "< 20", "ringan": "20–24", "sedang": "25–29", "berat": "≥ 30" },
          "male_40to59":    { "normal": "< 22", "ringan": "22–26", "sedang": "27–31", "berat": "≥ 32" },
          "male_60plus":    { "normal": "< 24", "ringan": "24–28", "sedang": "29–33", "berat": "≥ 34" },
          "female_under40": { "normal": "< 28", "ringan": "28–32", "sedang": "33–37", "berat": "≥ 38" },
          "female_40to59":  { "normal": "< 30", "ringan": "30–34", "sedang": "35–39", "berat": "≥ 40" },
          "female_60plus":  { "normal": "< 32", "ringan": "32–36", "sedang": "37–41", "berat": "≥ 42" }
        },
        "visceralFatIndex": {
          "source": "Tanita 1–59 scale",
          "normal": "1–9", "ringan": "10–14", "sedang": "15–19", "berat": "≥ 20"
        },
        "whr": {
          "source": "Universal cutoffs",
          "normal": "< 0.50", "ringan": "0.50–0.549", "sedang": "0.55–0.599", "berat": "≥ 0.60"
        }
      },
      "alertLogic": {
        "primary": [
          "bmi.zone !== normal",
          "wc.zone !== normal",
          "bf.zone !== normal",
          "vf.zone !== normal",
          "whr.zone !== normal"
        ],
        "highPriority": [
          "overallRiskScore >= 60"
        ],
        "confirmatoryTests": {
          "bmi_non_normal": "DEXA Scan or BIA — body fat % and lean mass distribution",
          "vf_non_normal":  "Abdominal ultrasound or CT — visceral adipose tissue volume",
          "whr_non_normal": "Metabolic panel + fasting insulin — cardiometabolic risk from central adiposity"
        }
      },
      "csvImport": {
        "template": "body_comp_template.csv",
        "templateFunction": "bcDownloadTemplate()",
        "parseFunction":    "bcParseCsv(text)",
        "confirmFunction":  "bcConfirmCsv()",
        "columns": ["gender","age","height_cm","weight_kg","bmi","waist_cm","body_fat_pct","visceral_fat_index","whr"]
      },
      "languageSupport": {
        "zoneBadges": "bcZoneLabel(zone) — bilingual EN/ID via bcRefreshLabels()",
        "bmrDisplay": "bmrTitle + bmrDesc bilingual in calcAll() render block",
        "updateTrigger": "bcRefreshLabels() called on language toggle (not calcAll())"
      },
      "charts": ["8-domain radar (higher=better inverted)", "8-domain horizontal bar"],
      "exportSection": "Section 9 in MD/TXT report; body_composition block in JSON Data Summary",
      "developerNotes": [
        "bc-* fields are never populated from the QRMA PDF pipeline — manual entry only.",
        "QRMA import modal denominator is 73 (bc-* excluded from count via bc- prefix filter).",
        "window.bcResult is set in calcAll() alongside bc zone data in window.zoneData.",
        "bcRefreshLabels() re-renders #r-bcal from cached window.bcResult on language toggle.",
        "Bilingual zone chips use bcZoneLabel(); EN maps berat to 'High Risk' not 'Berat'.",
        "aal() has optional 4th param forceTitleBlack=true for bc alert titles (black text on orange bg).",
        "nav() calls bcAutoCalc() on bodycomp page load to refresh derived fields.",
        "renderHrvStrip_BodyComp() is inline in the HTML — hrv-engine.js was not modified.",
        "HRV context sentence for body_comp not yet in hrv-engine.js getModuleContextSentence() — deferred B15."
      ]
    }
  ]
}
